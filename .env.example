# Copy this file to .env for local development (optional — defaults work fine locally).
# On your host (e.g. Render), set these as real environment variables in the dashboard.

# Port the Express server listens on. Most hosts (Render, Railway, etc.) set this automatically.
PORT=4000

# Secret used to sign login sessions (JWTs). MUST be set to a long random value in production —
# never rely on the built-in dev fallback outside your own machine.
JWT_SECRET=replace-with-a-long-random-string

# Set to "production" only when running `npm run start` after `npm run build` — this makes the
# Express server also serve the built frontend from /dist (see server/index.js).
NODE_ENV=development
